<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.barangay_health.controller.AllPatientsController"
      style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="32" right="36" bottom="32" left="36"/>
    </padding>
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="All Patients" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
                <Label text="Complete list of all appointments." style="-fx-font-size: 13px; -fx-text-fill: #6b7c93;" />
            </VBox>
            <Button text="⟳ Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #e8edf3; -fx-text-fill: #3a4a5c; -fx-font-size: 12px;
                           -fx-padding: 8 16 8 16; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #6b7c93; -fx-font-size: 12px;
                           -fx-padding: 8 16 8 16; -fx-background-radius: 8; -fx-cursor: hand;" />
        </HBox>

        <!-- Table -->
        <TableView fx:id="patientTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-radius: 12; -fx-effect: dropshadow(gaussian, #c5d3e0, 8, 0, 0, 2);">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
                <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="200" />
                <TableColumn fx:id="departmentColumn" text="Department" prefWidth="130" />
                <TableColumn fx:id="concernColumn" text="Concern / Notes" prefWidth="240" />
                <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" />
            </columns>
        </TableView>

        <!-- Delete Button -->
        <HBox>
            <Button text="🗑 Delete Selected" onAction="#handleDelete"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-padding: 10 24 10 24; -fx-background-radius: 8; -fx-cursor: hand;" />
        </HBox>
    </children>
</VBox>
