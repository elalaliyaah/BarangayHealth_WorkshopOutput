<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="28.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.barangay_health.controller.DashboardController"
      style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="36" right="40" bottom="36" left="40"/>
    </padding>
    <children>
        <!-- Header -->
        <VBox spacing="4">
            <Label text="Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
            <Label text="Patient count per department" style="-fx-font-size: 13px; -fx-text-fill: #6b7c93;" />
        </VBox>

        <!-- Cards Row -->
        <HBox spacing="20" alignment="CENTER">
            <!-- Medical Card -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 24; -fx-effect: dropshadow(gaussian, #c5d3e0, 8, 0, 0, 2);"
                  prefWidth="160">
                <Label text="🩺" style="-fx-font-size: 32px;" />
                <Label text="Medical" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d7dd2;" />
                <Label fx:id="medicalCountLabel" text="0"
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
                <Label text="patients" style="-fx-font-size: 12px; -fx-text-fill: #6b7c93;" />
            </VBox>

            <!-- Dental Card -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 24; -fx-effect: dropshadow(gaussian, #c5d3e0, 8, 0, 0, 2);"
                  prefWidth="160">
                <Label text="🦷" style="-fx-font-size: 32px;" />
                <Label text="Dental" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2a9d8f;" />
                <Label fx:id="dentalCountLabel" text="0"
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
                <Label text="patients" style="-fx-font-size: 12px; -fx-text-fill: #6b7c93;" />
            </VBox>

            <!-- Vaccination Card -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 24; -fx-effect: dropshadow(gaussian, #c5d3e0, 8, 0, 0, 2);"
                  prefWidth="160">
                <Label text="💉" style="-fx-font-size: 32px;" />
                <Label text="Vaccination" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e76f51;" />
                <Label fx:id="vaccinationCountLabel" text="0"
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
                <Label text="patients" style="-fx-font-size: 12px; -fx-text-fill: #6b7c93;" />
            </VBox>
        </HBox>

        <!-- Action Buttons -->
        <HBox spacing="16" alignment="CENTER">
            <Button text="+ Add Patient" onAction="#handleAddPatient"
                    style="-fx-background-color: #2d7dd2; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-padding: 10 28 10 28; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="View All Patients" onAction="#handleViewAll"
                    style="-fx-background-color: white; -fx-text-fill: #2d7dd2; -fx-font-size: 13px;
                           -fx-padding: 10 28 10 28; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-border-color: #2d7dd2; -fx-border-radius: 8;" />
        </HBox>
    </children>
</VBox>
