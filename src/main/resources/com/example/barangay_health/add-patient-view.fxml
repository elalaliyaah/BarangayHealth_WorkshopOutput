<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="24.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.barangay_health.controller.AddPatientController"
      style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="36" right="40" bottom="36" left="40"/>
    </padding>
    <children>
        <!-- Header -->
        <VBox spacing="4">
            <Label text="Add Patient" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;" />
            <Label text="Fill in the patient's appointment details." style="-fx-font-size: 13px; -fx-text-fill: #6b7c93;" />
        </VBox>

        <!-- Form Card -->
        <VBox spacing="16"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 28; -fx-effect: dropshadow(gaussian, #c5d3e0, 8, 0, 0, 2);">
            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" />
                    <ColumnConstraints prefWidth="280" />
                </columnConstraints>

                <Label text="Patient Name" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3a4a5c;" />
                <TextField fx:id="nameField" promptText="e.g. Juan Dela Cruz"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           style="-fx-background-radius: 6;" />

                <Label text="Department" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3a4a5c;" />
                <ComboBox fx:id="departmentComboBox" promptText="Select department"
                          GridPane.rowIndex="1" GridPane.columnIndex="1"
                          maxWidth="Infinity"
                          style="-fx-background-radius: 6;" />

                <Label text="Concern / Notes" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3a4a5c;" />
                <TextField fx:id="concernField" promptText="e.g. Headache, Tooth extraction..."
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           style="-fx-background-radius: 6;" />

                <Label text="Appointment Date" GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3a4a5c;" />
                <DatePicker fx:id="datePicker"
                            GridPane.rowIndex="3" GridPane.columnIndex="1"
                            maxWidth="Infinity"
                            style="-fx-background-radius: 6;" />
            </GridPane>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="Save Patient" onAction="#handleSave"
                    style="-fx-background-color: #2d7dd2; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-padding: 10 28 10 28; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="Clear" onAction="#handleClear"
                    style="-fx-background-color: #e8edf3; -fx-text-fill: #3a4a5c; -fx-font-size: 13px;
                           -fx-padding: 10 20 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #6b7c93; -fx-font-size: 13px;
                           -fx-padding: 10 20 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
        </HBox>
    </children>
</VBox>
